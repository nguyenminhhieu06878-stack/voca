// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("student")
  googleId  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practices    Practice[]
  quizSessions QuizSession[]
  reviewItems  ReviewItem[]

  @@map("users")
}

model Vocabulary {
  id          String   @id @default(cuid())
  word        String   @unique
  translation String
  category    String
  difficulty  String   @default("easy")
  audioUrl    String?
  phonetic    String?
  example     String?
  type        String   @default("word") // "word", "phrase", "sentence"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  practices   Practice[]
  reviewItems ReviewItem[]

  @@map("vocabulary")
}

model Practice {
  id            String   @id @default(cuid())
  userId        String
  vocabularyId  String
  transcription String
  score         Int
  feedback      String
  isCorrect     Boolean
  audioPath     String?
  mode          String   @default("practice") // "practice", "quiz", "review"
  quizSessionId String?  // Link to quiz session if this is part of a quiz
  createdAt     DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary   Vocabulary    @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  quizSession  QuizSession?  @relation(fields: [quizSessionId], references: [id], onDelete: Cascade)

  @@map("practices")
}

model ReviewItem {
  id           String   @id @default(cuid())
  userId       String
  vocabularyId String
  lastScore    Int      // Latest score from practice
  attempts     Int      @default(1) // Number of review attempts
  needsReview  Boolean  @default(true) // Whether this item needs review
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
  @@map("review_items")
}

model QuizSession {
  id          String   @id @default(cuid())
  userId      String
  title       String   // e.g., "Animals Quiz - 10 Questions"
  category    String
  difficulty  String
  practiceMode String  @default("words") // "words" or "phrases"
  totalScore  Int      @default(0)
  maxScore    Int      @default(0)
  timeLimit   Int?     // in minutes
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  practices Practice[]

  @@map("quiz_sessions")
}